SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=students_life
DB_USER=students_life_user
DB_PASSWORD=students_life_password
DB_HOST=db
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19000,http://localhost:19006,http://127.0.0.1:3000,http://127.0.0.1:8081,http://127.0.0.1:19000,http://127.0.0.1:19006,https://stud-life.com,https://www.stud-life.com
CORS_ALLOWED_ORIGIN_REGEXES=^http://localhost:\d+$,^http://127\.0\.0\.1:\d+$
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_PRIVATE_NETWORK=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19000,http://localhost:19006,http://127.0.0.1:3000,http://127.0.0.1:8081,http://127.0.0.1:19000,http://127.0.0.1:19006,https://stud-life.com,https://www.stud-life.com
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

REDIS_URL=redis://redis:6379/0

LANGUAGE_CODE=ru
TIME_ZONE=Europe/Moscow

STATIC_URL=/static/
MEDIA_URL=/media/

FIREBASE_CREDENTIALS_PATH=

# External manager-sl API integration.
# Example: http://localhost:8001/api
MANAGER_SL_API_BASE_URL=
MANAGER_SL_LEADS_API_KEY=
MANAGER_SL_TIMEOUT_SECONDS=8
MANAGER_SL_AUTH_BASE_URL=https://manager-sl.ru

# API abuse protection.
THROTTLE_REGISTER_RATE=5/hour
THROTTLE_LOGIN_RATE=10/min
THROTTLE_APPLICATION_CREATE_RATE=5/hour
THROTTLE_PUSH_TOKEN_RATE=10/min
THROTTLE_ACTIVITY_RATE=60/min
THROTTLE_CHAT_MESSAGE_RATE=20/min
THROTTLE_CHAT_UPLOAD_RATE=10/min

# Chat photo validation/compression limits, in bytes/pixels.
CHAT_IMAGE_MAX_UPLOAD_SIZE=6291456
CHAT_IMAGE_MAX_STORED_SIZE=2097152
CHAT_IMAGE_MAX_DIMENSION=1600

# Application document upload limit, in bytes.
APPLICATION_FILE_MAX_UPLOAD_SIZE=10485760

# Polling is the default chat transport. Enable WebSocket only behind trusted TLS/proxy logging config.
CHAT_WEBSOCKET_ENABLED=False
CHAT_WEBSOCKET_ALLOW_QUERY_TOKEN=False

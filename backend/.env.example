THROTTLE_LOGIN_RATE=10/min
THROTTLE_APPLICATION_CREATE_RATE=5/hour
THROTTLE_PUSH_TOKEN_RATE=10/min
THROTTLE_ACTIVITY_RATE=60/min
THROTTLE_CHAT_MESSAGE_RATE=20/min
